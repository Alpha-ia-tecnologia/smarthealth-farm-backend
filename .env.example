# ===== Smart Health CAHOSP — Backend · variaveis de ambiente =====
# Copie para .env e preencha. NUNCA commite o .env (ja esta no .gitignore).

# --- Servidor ---
PORT=3002

# --- Banco PostgreSQL (URL externa fornecida por voce) ---
# Formato JDBC, ex.: jdbc:postgresql://host:5432/cahosp
DB_URL=jdbc:postgresql://localhost:5432/cahosp
DB_USERNAME=postgres
DB_PASSWORD=

# --- CORS (origens do frontend, separadas por virgula) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- JWT (Fase 1) ---
# Segredo forte (>= 32 bytes). Gere um aleatorio em producao.
JWT_SECRET=
# Expiracao do token em milissegundos (default 24h = 86400000)
JWT_EXPIRES_IN=86400000

# --- Administrador inicial (criado no startup SE nao existir) ---
ADMIN_NOME=Administrador CAHOSP
ADMIN_EMAIL=admin@cahosp.local
ADMIN_SENHA=

# --- Integracao EMSERH (Fase 9) ---
INTEGRACAO_ENABLED=false

# --- Provedores de IA (Fase 10 — opcionais; sem chave => modo demo) ---
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
